@{
    ViewData["Title"] = "Access Denied";
}

<div class="pagetitle">
    <h1>Access Denied</h1>
    <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item active">403 - Forbidden</li></ol></nav>
</div>

<section class="section">
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-shield-lock" style="font-size: 80px; color: #e74c3c;"></i>
            <h2 class="mt-3 text-danger">Access Denied</h2>
            <p class="text-muted fs-5 mt-2">You don't have permission to access this page.</p>
            <p class="text-muted">Your role: <span class="badge bg-primary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span></p>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
                    <i class="bi bi-house me-1"></i> Go to Dashboard
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Go Back
                </a>
            </div>
        </div>
    </div>
</section>
