@model spms.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">

            <div class="login-card shadow-lg animate__animated animate__fadeIn">
                
                <!-- Header Section -->
                <div class="login-header text-center">
                    <div class="logo-wrapper mb-3">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <h2 class="fw-bold text-white mb-1">SPMS</h2>
                    <p class="text-white-50 small">Student Project Management System</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-dark">Login</h4>
                        <p class="text-muted small">Access your management dashboard</p>
                    </div>

                    <!-- Alert Messages -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Validation Errors -->
                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger border-0 shadow-sm" asp-validation-summary="ModelOnly"></div>
                    }

                    <form asp-action="Login" method="post" class="needs-validation">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <!-- Email Field -->
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" autofocus>
                            <label asp-for="Email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password Field -->
                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Password" type="password" class="form-control" id="passwordInput" placeholder="Password">
                            <label asp-for="Password"><i class="bi bi-lock me-2"></i>Password</label>
                            <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 border-0" id="togglePassword">
                                <i class="bi bi-eye text-muted" id="toggleIcon"></i>
                            </button>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember & Meta -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                                <label asp-for="RememberMe" class="form-check-label text-muted small">Remember me</label>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm login-btn">
                            Sign In <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <!-- Demo Accounts -->
                    <div class="demo-section mt-5 p-3 rounded-4 border border-info border-opacity-25 bg-info bg-opacity-10">
                        <p class="small fw-bold text-info mb-3 text-center"><i class="bi bi-shield-check me-2"></i>Demo Accounts</p>
                        <div class="d-grid gap-2">
                             <div class="d-flex justify-content-between align-items-center bg-white p-2 rounded-3 shadow-sm mb-1">
                                <span class="badge bg-danger rounded-pill px-3">Admin</span>
                                <code class="text-dark small">admin@spms.com</code>
                                <code class="text-primary fw-bold small">admin123</code>
                            </div>
                            <div class="d-flex justify-content-between align-items-center bg-white p-2 rounded-3 shadow-sm mb-1">
                                <span class="badge bg-success rounded-pill px-3">Faculty</span>
                                <code class="text-dark small">priya.sharma@spms.com</code>
                                <code class="text-primary fw-bold small">faculty123</code>
                            </div>
                            <div class="d-flex justify-content-between align-items-center bg-white p-2 rounded-3 shadow-sm">
                                <span class="badge bg-info rounded-pill px-3">Student</span>
                                <code class="text-dark small">rohan.mehta@spms.com</code>
                                <code class="text-primary fw-bold small">student123</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="text-center text-white-50 mt-4 small">
                &copy; @DateTime.Now.Year SPMS. Secure Access Portal.
            </p>

        </div>
    </div>
</div>

<script>
    // Toggle password visibility
    document.getElementById('togglePassword').addEventListener('click', function() {
        var input = document.getElementById('passwordInput');
        var icon = document.getElementById('toggleIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    });
</script>
