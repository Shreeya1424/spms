@model List<spms.Models.RoleModel>
@{ ViewData["Title"] = "Manage Roles"; }

<div class="pagetitle">
    <h1>Manage Roles</h1>
    <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item active">Roles</li></ol></nav>
</div>

<section class="section">
    <div class="card">
        <div class="card-body">
            <div class="top-action-bar mt-3">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="tableSearchInput" class="form-control" placeholder="Search roles...">
                </div>
                <a asp-action="Create" class="btn btn-primary btn-add"><i class="bi bi-plus-lg me-1"></i> Add Role</a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover" id="dataTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Role Name</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model)
                        {
                            <tr>
                                <td>@role.Id</td>
                                <td><strong>@role.RoleName</strong></td>
                                <td>@role.Description</td>
                                <td class="action-btns">
                                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this role?')"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:48px;"></i><p class="mt-2">No roles found.</p></div>
            }
        </div>
    </div>
</section>
