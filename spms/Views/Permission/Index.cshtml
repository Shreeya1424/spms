@model spms.Models.RolePermissionViewModel
@{ ViewData["Title"] = "Role & Permissions"; }

<div class="pagetitle">
    <h1>Role &amp; Permissions</h1>
    <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item active">Permissions</li></ol></nav>
</div>

<section class="section">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Assign Permissions to Roles</h5>
            <p class="text-muted">Toggle checkboxes to grant or revoke permissions for each role.</p>

            <div class="table-responsive">
                <table class="table table-bordered permission-grid">
                    <thead>
                        <tr>
                            <th style="min-width:200px;">Permission</th>
                            @foreach (var role in Model.Roles)
                            {
                                <th>@role.RoleName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var perm in Model.Permissions)
                        {
                            <tr>
                                <td>
                                    <strong>@perm.PermissionName</strong>
                                    <br><small class="text-muted">@perm.Description</small>
                                </td>
                                @foreach (var role in Model.Roles)
                                {
                                    var rp = Model.RolePermissions.FirstOrDefault(x => x.RoleId == role.Id && x.PermissionId == perm.Id);
                                    var isChecked = rp?.IsGranted ?? false;
                                    <td>
                                        <form asp-action="Update" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="roleId" value="@role.Id" />
                                            <input type="hidden" name="permissionId" value="@perm.Id" />
                                            <input type="hidden" name="isGranted" value="@(!isChecked)" />
                                            <button type="submit" class="btn btn-link p-0" title="Toggle permission">
                                                @if (isChecked)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success" style="font-size:22px;"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle text-danger" style="font-size:22px;"></i>
                                                }
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Legend -->
            <div class="mt-3">
                <span class="me-3"><i class="bi bi-check-circle-fill text-success"></i> Granted</span>
                <span><i class="bi bi-x-circle text-danger"></i> Denied</span>
            </div>
        </div>
    </div>
</section>
