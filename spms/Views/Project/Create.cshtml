@model spms.Models.ProjectModel
@{
    ViewData["Title"] = "Add Project";
    var students = ViewData["Students"] as List<spms.Models.StudentModel>;
    var faculty = ViewData["Faculty"] as List<spms.Models.FacultyModel>;
}

<div class="pagetitle">
    <h1>Add Project</h1>
    <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item"><a asp-controller="Project" asp-action="Index">Projects</a></li><li class="breadcrumb-item active">Add</li></ol></nav>
</div>

<section class="section">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Project Details</h5>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row mb-3">
                    <label asp-for="ProjectTitle" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><input asp-for="ProjectTitle" class="form-control" placeholder="Enter project title"><span asp-validation-for="ProjectTitle" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Description" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description"></textarea></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="StartDate" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-4"><input asp-for="StartDate" type="date" class="form-control"><span asp-validation-for="StartDate" class="text-danger"></span></div>
                    <label asp-for="EndDate" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-4"><input asp-for="EndDate" type="date" class="form-control"><span asp-validation-for="EndDate" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Status" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-4">
                        <select asp-for="Status" class="form-select">
                            <option>Not Started</option><option>In Progress</option><option>Completed</option>
                        </select>
                    </div>
                    <label asp-for="FacultyId" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-4">
                        <select asp-for="FacultyId" class="form-select">
                            <option value="">-- Select Faculty --</option>
                            @if (faculty != null) { foreach(var f in faculty) { <option value="@f.Id">@f.FacultyName</option> } }
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="StudentIds" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <select asp-for="StudentIds" class="form-select" multiple size="4">
                            @if (students != null) { foreach(var s in students) { <option value="@s.Id">@s.StudentName</option> } }
                        </select>
                        <small class="text-muted">Hold Ctrl key to select multiple students.</small>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-10 offset-sm-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Save</button>
                        <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left me-1"></i> Back</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
