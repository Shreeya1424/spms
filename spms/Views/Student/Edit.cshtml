@model spms.Models.StudentModel
@{ ViewData["Title"] = "Edit Student"; }

<div class="pagetitle">
    <h1>Edit Student</h1>
    <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item"><a asp-controller="Student" asp-action="Index">Students</a></li><li class="breadcrumb-item active">Edit</li></ol></nav>
</div>

<section class="section">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Edit Student Details</h5>
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row mb-3">
                    <label asp-for="StudentName" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><input asp-for="StudentName" class="form-control"><span asp-validation-for="StudentName" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="EnrollmentNo" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><input asp-for="EnrollmentNo" class="form-control"><span asp-validation-for="EnrollmentNo" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Department" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10">
                        <select asp-for="Department" class="form-select">
                            <option value="">-- Select --</option>
                            <option>Computer Science</option><option>Information Technology</option><option>Electronics</option><option>Mechanical</option><option>Civil</option>
                        </select>
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Email" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><input asp-for="Email" type="email" class="form-control"><span asp-validation-for="Email" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <label asp-for="Mobile" class="col-sm-2 col-form-label"></label>
                    <div class="col-sm-10"><input asp-for="Mobile" class="form-control"><span asp-validation-for="Mobile" class="text-danger"></span></div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-10 offset-sm-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Update</button>
                        <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left me-1"></i> Back</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
